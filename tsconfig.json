{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2022"],
    "types": ["vitest/globals"]
  },
  "include": [
    "src/client/app/**/*.js",
    "src/client/app/**/*.d.ts"
  ]
}
