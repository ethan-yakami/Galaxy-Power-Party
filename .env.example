NODE_ENV=production
HOST=0.0.0.0
PORT=3000
GPP_APP_VERSION=1.1.1

# Storage
GPP_STORE_PROVIDER=prisma
DATABASE_URL=postgresql://user:password@host:5432/galaxy_power_party?schema=public

# Security (MUST be strong random strings in production, >= 32 chars)
GPP_ACCESS_TOKEN_SECRET=replace-with-random-access-secret
GPP_REFRESH_TOKEN_SECRET=replace-with-random-refresh-secret
GPP_ADMIN_TOKEN=replace-with-random-admin-token

# Optional tuning
GPP_AUTH_RATE_LIMIT_WINDOW_MS=60000
GPP_AUTH_RATE_LIMIT_MAX=20
GPP_AUTH_RATE_LIMIT_BAN_MS=300000
GPP_WS_HANDSHAKE_RATE_LIMIT_WINDOW_MS=60000
GPP_WS_HANDSHAKE_RATE_LIMIT_MAX=30
GPP_WS_HANDSHAKE_RATE_LIMIT_BAN_MS=120000
GPP_WS_ACTION_RATE_LIMIT_WINDOW_MS=10000
GPP_WS_ACTION_RATE_LIMIT_MAX=24
GPP_WS_ACTION_RATE_LIMIT_BAN_MS=60000
GPP_ROOM_CLEANUP_INTERVAL_MS=30000
GPP_ROOM_IDLE_TTL_MS=1800000
GPP_PLAYER_OFFLINE_GRACE_MS=120000
GPP_SESSION_CLEANUP_INTERVAL_MS=600000
